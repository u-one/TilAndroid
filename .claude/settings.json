{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "grep -qE '\\.(kt|kts)\"' && ./gradlew spotlessApply 2>&1 | tail -5 || true",
            "timeout": 120,
            "statusMessage": "Spotless フォーマット適用中..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./gradlew test 2>&1 | tail -20 || true",
            "timeout": 300,
            "statusMessage": "単体テスト実行中..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "compose-expert@aldefy-compose-skill": true
  }
}
